APP_NAME=JerseyHolic
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# New System Database
DB_CONNECTION=central
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=jerseyholic_new
DB_USERNAME=root
DB_PASSWORD=

# Central Database (multi-tenancy)
DB_DATABASE_CENTRAL=jerseyholic_central

# Central Domain
CENTRAL_DOMAIN=admin.jerseyholic.com

# Legacy OpenCart Database (for migration)
DB_OC_HOST=127.0.0.1
DB_OC_PORT=3306
DB_OC_DATABASE=jerseyholic_oc
DB_OC_USERNAME=root
DB_OC_PASSWORD=

# Legacy ThinkPHP Database (for migration)
DB_TP_HOST=127.0.0.1
DB_TP_PORT=3306
DB_TP_DATABASE=jerseyholic_tp
DB_TP_USERNAME=root
DB_TP_PASSWORD=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0

# Queue
QUEUE_CONNECTION=redis

# Cache
CACHE_DRIVER=redis

# Session
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:3001

# PayPal
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Facebook Pixel
FB_PIXEL_ID=
FB_ACCESS_TOKEN=

# Log
LOG_CHANNEL=daily
LOG_LEVEL=debug

# Mail
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@jerseyholic.xyz
MAIL_FROM_NAME=JerseyHolic

# Scramble API Documentation
SCRAMBLE_ENABLED=true
